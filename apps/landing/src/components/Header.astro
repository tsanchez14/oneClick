---
// Header.astro
---
<header class="sticky top-0 z-50 w-full border-b border-gray-100 bg-white/80 backdrop-blur-md">
  <div class="container mx-auto px-4 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <div class="bg-[#2563eb] text-white p-1.5 rounded-lg group-hover:scale-105 transition-transform">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
          <line x1="16" x2="16" y1="2" y2="6"/>
          <line x1="8" x2="8" y1="2" y2="6"/>
          <line x1="3" x2="21" y1="10" y2="10"/>
          <path d="m9 16 2 2 4-4"/>
        </svg>
      </div>
      <span class="text-xl font-bold tracking-tight text-[#0f1729]">onClick</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="#funcionalidades" class="text-sm font-medium text-gray-600 hover:text-[#2563eb] transition-colors">Funcionalidades</a>
      <a href="#precios" class="text-sm font-medium text-gray-600 hover:text-[#2563eb] transition-colors">Precios</a>
      <a href="#faqs" class="text-sm font-medium text-gray-600 hover:text-[#2563eb] transition-colors">FAQs</a>
    </nav>

    <!-- Desktop Actions -->
    <div class="hidden md:flex items-center gap-4">
      <a href="http://localhost:5173/login" class="text-sm font-medium text-[#0f1729] border border-gray-200 hover:border-gray-300 hover:bg-gray-50 px-4 py-2 rounded-lg transition-all">
        Iniciar sesión
      </a>
      <a href="http://localhost:5173/register" class="text-sm font-medium text-white bg-[#2563eb] hover:bg-[#1d4ed8] px-4 py-2 rounded-lg shadow-sm shadow-blue-500/20 transition-all">
        Registrarse
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button class="md:hidden p-2 text-gray-600" id="mobile-menu-btn" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" x2="20" y1="12" y2="12"/>
        <line x1="4" x2="20" y1="6" y2="6"/>
        <line x1="4" x2="20" y1="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <div class="flex flex-col px-4 py-6 space-y-4">
      <a href="#funcionalidades" class="text-base font-medium text-gray-600 mobile-link">Funcionalidades</a>
      <a href="#precios" class="text-base font-medium text-gray-600 mobile-link">Precios</a>
      <a href="#faqs" class="text-base font-medium text-gray-600 mobile-link">FAQs</a>
      <hr class="border-gray-100" />
      <a href="http://localhost:5173/login" class="text-center text-base font-medium text-[#0f1729] border border-gray-200 py-2.5 rounded-lg w-full">
        Iniciar sesión
      </a>
      <a href="http://localhost:5173/register" class="text-center text-base font-medium text-white bg-[#2563eb] py-2.5 rounded-lg w-full">
        Registrarse
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const links = document.querySelectorAll('.mobile-link');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });

    links.forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
      });
    });
  }
</script>
