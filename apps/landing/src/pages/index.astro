---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Pricing from '../components/Pricing.astro';
import { Faqs } from '../components/Faqs';
import Footer from '../components/Footer.astro';
---

<Layout title="onClick | Tu agenda profesional, en un click">
  <Header />
  
  <main>
    <Hero />
    <Features />
    <Pricing />
    
    <section id="faqs" class="py-20 bg-gray-50">
      <div class="container mx-auto px-4 max-w-3xl">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[#0f1729] mb-4">Preguntas Frecuentes</h2>
          <p class="text-lg text-gray-600">Todo lo que necesitás saber sobre onClick.</p>
        </div>
        
        <!-- React Island: se hidrata solo cuando es visible -->
        <Faqs client:visible />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
